
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Learning DNA v2</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: #0A0914;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 24px 12px;
  overflow-x: hidden;
}

/* ── STAGE ── */
.stage {
  display: flex;
  gap: 20px;
  align-items: flex-start;
  justify-content: center;
  width: 100%;
  max-width: 780px;
}

/* ── COACH SIDEBAR ── */
.coach-sidebar {
  width: 140px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  position: sticky;
  top: 24px;
}

.coach-avatar-wrap {
  position: relative;
  width: 80px;
  height: 80px;
}

.coach-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B21B6, #7C3AED);
  border: 2.5px solid #A78BFA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  cursor: pointer;
  transition: transform 0.2s;
  position: relative;
  overflow: hidden;
}

.coach-avatar:hover { transform: scale(1.04); }

.coach-avatar-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 0;
}

/* placeholder person silhouette */
.avatar-body {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  margin-bottom: -4px;
  position: relative;
  z-index: 2;
}
.avatar-shoulders {
  width: 52px;
  height: 28px;
  border-radius: 26px 26px 0 0;
  background: rgba(255,255,255,0.18);
  position: relative;
  z-index: 1;
}

.coach-status {
  position: absolute;
  bottom: 3px;
  right: 3px;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #22C55E;
  border: 2px solid #0A0914;
}

.coach-name {
  font-size: 13px;
  font-weight: 500;
  color: #fff;
  text-align: center;
}

.coach-role {
  font-size: 10px;
  color: rgba(255,255,255,0.45);
  text-align: center;
  line-height: 1.4;
}

.coach-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 8px;
  border-radius: 20px;
  background: rgba(167,139,250,0.15);
  border: 1px solid rgba(167,139,250,0.3);
  font-size: 9px;
  color: #A78BFA;
  font-weight: 500;
}

.coach-nudge {
  background: #1A1535;
  border: 1px solid rgba(167,139,250,0.2);
  border-radius: 12px;
  padding: 10px;
  font-size: 10px;
  color: rgba(255,255,255,0.6);
  line-height: 1.5;
  text-align: center;
  position: relative;
}

.coach-nudge::before {
  content: '';
  position: absolute;
  top: -6px;
  left: 50%;
  transform: translateX(-50%);
  width: 10px;
  height: 6px;
  background: #1A1535;
  clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
}

.coach-nudge strong {
  color: #C4B5FD;
  font-weight: 500;
}

.coach-actions {
  display: flex;
  flex-direction: column;
  gap: 6px;
  width: 100%;
}

.coach-act-btn {
  width: 100%;
  padding: 7px 10px;
  border-radius: 8px;
  border: 1px solid rgba(124,58,237,0.35);
  background: rgba(124,58,237,0.1);
  color: #A78BFA;
  font-size: 10px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: background 0.15s;
}
.coach-act-btn:hover { background: rgba(124,58,237,0.2); }
.coach-act-btn i { font-size: 12px; }

/* ── PHONE ── */
.phone-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.phone-label {
  font-size: 10px;
  color: rgba(255,255,255,0.2);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.phone {
  width: 300px;
  height: 600px;
  border-radius: 38px;
  border: 7px solid #1E1B35;
  background: #0D0B1E;
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 0 1px rgba(167,139,250,0.12), 0 32px 64px -16px rgba(0,0,0,0.7);
}

.phone-notch {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80px;
  height: 20px;
  background: #1E1B35;
  border-radius: 0 0 14px 14px;
  z-index: 100;
}

.phone-screen {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── TOPBAR ── */
.topbar {
  background: #130F2A;
  padding: 26px 12px 9px;
  display: flex;
  align-items: center;
  gap: 7px;
  flex-shrink: 0;
  z-index: 80;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.logo-mark {
  width: 22px;
  height: 22px;
  border-radius: 6px;
  background: #7C3AED;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  flex-shrink: 0;
}

.topbar-title {
  font-size: 12px;
  font-weight: 600;
  color: #fff;
  flex: 1;
  letter-spacing: 0.01em;
}
.topbar-title span { color: #A78BFA; }

.topbar-icons {
  display: flex;
  gap: 7px;
  align-items: center;
}

.tb-av {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #5B21B6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 8px;
  color: #fff;
  border: 1.5px solid #A78BFA;
}

/* ── PAGES ── */
.pages {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.pg {
  position: absolute;
  inset: 0;
  overflow-y: auto;
  display: none;
  flex-direction: column;
  scrollbar-width: none;
}
.pg::-webkit-scrollbar { display: none; }
.pg.active { display: flex; }

.pg-content {
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding-bottom: 76px;
}

/* ── NAV ── */
.navbar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60px;
  background: #130F2A;
  border-top: 1px solid rgba(255,255,255,0.07);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 4px;
  flex-shrink: 0;
  z-index: 90;
}

.nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 6px 8px;
  border-radius: 10px;
  cursor: pointer;
  border: none;
  background: transparent;
  flex: 1;
}
.nav-btn i { font-size: 17px; color: rgba(255,255,255,0.3); }
.nav-btn span { font-size: 8px; color: rgba(255,255,255,0.3); }
.nav-btn.active i, .nav-btn.active span { color: #A78BFA; }
.nav-btn.active { background: rgba(124,58,237,0.12); }

/* ── CARDS ── */
.card {
  background: #16123A;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px;
  padding: 11px;
}

.card-sm {
  background: #16123A;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 12px;
  padding: 9px 10px;
}

/* ── HERO BANNER ── */
.hero {
  background: #2D1B6B;
  border-radius: 14px;
  padding: 12px;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '🧬';
  position: absolute;
  right: -4px;
  top: -8px;
  font-size: 52px;
  opacity: 0.08;
  pointer-events: none;
}

.hero-eyebrow {
  font-size: 8px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.hero h2 {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 3px;
}

.hero p {
  font-size: 9px;
  color: rgba(255,255,255,0.55);
  line-height: 1.5;
}

/* ── COACH STRIP (inside phone) ── */
.coach-strip {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 9px 11px;
  background: rgba(124,58,237,0.1);
  border: 1px solid rgba(124,58,237,0.22);
  border-radius: 12px;
}

.cs-av {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #5B21B6;
  border: 1.5px solid #A78BFA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
  overflow: hidden;
  flex-direction: column;
}
.cs-av-head { width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.3); margin-bottom: -2px; }
.cs-av-body { width: 22px; height: 12px; border-radius: 11px 11px 0 0; background: rgba(255,255,255,0.2); }

.cs-content { flex: 1; }
.cs-name { font-size: 10px; font-weight: 500; color: #fff; }
.cs-msg { font-size: 9px; color: rgba(255,255,255,0.5); line-height: 1.4; margin-top: 1px; }

.cs-btn {
  padding: 5px 9px;
  border-radius: 7px;
  background: #7C3AED;
  border: none;
  color: #fff;
  font-size: 9px;
  cursor: pointer;
  flex-shrink: 0;
}

/* ── STATS ── */
.g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; }
.stat-label { font-size: 8px; color: rgba(255,255,255,0.4); margin-bottom: 2px; }
.stat-val { font-size: 17px; font-weight: 600; color: #fff; }
.stat-sub { font-size: 8px; color: rgba(255,255,255,0.3); margin-top: 1px; }

.pb { height: 3px; background: rgba(255,255,255,0.07); border-radius: 2px; margin-top: 5px; }
.pf { height: 3px; border-radius: 2px; }

/* ── PILLS ── */
.pill { display: inline-flex; align-items: center; gap: 3px; padding: 2px 7px; border-radius: 20px; font-size: 8px; font-weight: 500; }
.pill-p { background: rgba(139,92,246,0.18); color: #C4B5FD; }
.pill-g { background: rgba(34,197,94,0.15); color: #86EFAC; }
.pill-a { background: rgba(251,191,36,0.12); color: #FCD34D; }
.pill-b { background: rgba(96,165,250,0.12); color: #93C5FD; }

/* ── SECT TITLE ── */
.sect-title {
  font-size: 10px;
  color: rgba(255,255,255,0.4);
  font-weight: 500;
  margin-bottom: 7px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.sect-title span { font-size: 9px; color: #8B5CF6; cursor: pointer; }

/* ── SCHEDULE ── */
.sched-row {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 7px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.sched-row:last-child { border-bottom: none; }
.sched-time { font-size: 8px; color: rgba(255,255,255,0.3); min-width: 36px; }
.sched-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
.sched-ttl { font-size: 10px; color: #fff; }
.sched-sub { font-size: 8px; color: rgba(255,255,255,0.35); }

/* ── CHAT ── */
.msg { max-width: 82%; margin-bottom: 7px; }
.msg.ai { align-self: flex-start; }
.msg.user { align-self: flex-end; }
.bubble { padding: 7px 10px; border-radius: 10px; font-size: 9px; line-height: 1.5; }
.msg.ai .bubble { background: #1E1A40; border: 1px solid rgba(255,255,255,0.06); color: rgba(255,255,255,0.85); border-radius: 3px 10px 10px 10px; }
.msg.user .bubble { background: #7C3AED; color: #fff; border-radius: 10px 3px 10px 10px; }
.msg-name { font-size: 7px; color: rgba(255,255,255,0.3); margin-bottom: 2px; }

.chat-av {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #5B21B6;
  border: 1px solid #A78BFA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  flex-shrink: 0;
  margin-top: 2px;
  overflow: hidden;
  flex-direction: column;
}
.chat-av-h { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.35); margin-bottom: -1px; }
.chat-av-b { width: 14px; height: 8px; border-radius: 7px 7px 0 0; background: rgba(255,255,255,0.22); }

.msg-row { display: flex; gap: 5px; align-items: flex-start; }

.chat-input {
  display: flex;
  gap: 5px;
  padding: 8px 10px;
  background: #130F2A;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding-bottom: 72px;
}
.chat-input input {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 6px 9px;
  color: #fff;
  font-size: 9px;
  outline: none;
}
.chat-input input::placeholder { color: rgba(255,255,255,0.25); }
.send-b {
  background: #7C3AED;
  border: none;
  border-radius: 7px;
  width: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #fff;
  font-size: 12px;
}

/* ── ANALYTICS ── */
.bar-chart { display: flex; align-items: flex-end; gap: 3px; height: 56px; margin-top: 4px; }
.bar-col { display: flex; flex-direction: column; align-items: center; flex: 1; gap: 2px; }
.bar { width: 100%; border-radius: 3px 3px 0 0; }
.bar-lbl { font-size: 7px; color: rgba(255,255,255,0.3); }

/* ── BADGES ── */
.badge-g { display: grid; grid-template-columns: repeat(3,1fr); gap: 5px; }
.badge-item { display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 9px 4px; border-radius: 8px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }
.badge-ic { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; }
.badge-nm { font-size: 7px; color: rgba(255,255,255,0.75); text-align: center; }

/* ── LEADERBOARD ── */
.lb-item { display: flex; align-items: center; gap: 6px; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
.lb-item:last-child { border-bottom: none; }
.lb-av { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 8px; font-weight: 500; }
.lb-nm { flex: 1; font-size: 10px; color: rgba(255,255,255,0.75); }
.lb-pt { font-size: 9px; color: #A78BFA; font-weight: 500; }

/* ── DNA TRAITS ── */
.dna-trait { display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
.dna-trait:last-child { border-bottom: none; }
.dna-tn { font-size: 9px; color: rgba(255,255,255,0.45); }
.dna-tv { font-size: 9px; font-weight: 500; color: #A78BFA; }

/* ── ONBOARDING ── */
.ob-overlay {
  position: absolute;
  inset: 0;
  background: #0D0B1E;
  z-index: 50;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14px;
  gap: 10px;
}
.ob-overlay.hide { display: none; }

.ob-opts { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; width: 100%; }
.ob-opt {
  padding: 8px;
  border-radius: 9px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.04);
  font-size: 10px;
  color: rgba(255,255,255,0.6);
  cursor: pointer;
  text-align: center;
  transition: all 0.15s;
}
.ob-opt.sel { border-color: #7C3AED; background: rgba(124,58,237,0.2); color: #fff; }

.ob-btn {
  background: #7C3AED;
  color: #fff;
  border: none;
  border-radius: 9px;
  padding: 9px;
  font-size: 11px;
  cursor: pointer;
  width: 100%;
}

.ob-d { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.15); }
.ob-d.on { background: #7C3AED; width: 14px; border-radius: 3px; }
.ob-dots { display: flex; gap: 4px; justify-content: center; }

/* ── PERSONALITY CARD (onboarding step) ── */
.pers-card {
  background: #1E1A40;
  border: 1px solid rgba(124,58,237,0.25);
  border-radius: 12px;
  padding: 10px;
  cursor: pointer;
  transition: border-color 0.15s;
  display: flex;
  align-items: center;
  gap: 9px;
  width: 100%;
}
.pers-card.sel { border-color: #7C3AED; background: rgba(124,58,237,0.15); }
.pers-icon {
  width: 36px; height: 36px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}
.pers-info { flex: 1; }
.pers-name { font-size: 11px; font-weight: 500; color: #fff; }
.pers-desc { font-size: 8px; color: rgba(255,255,255,0.4); margin-top: 1px; }
.pers-badge { font-size: 8px; padding: 2px 6px; border-radius: 10px; font-weight: 500; }

/* ── SUBJECT CARDS ── */
.subj-card { border-radius: 12px; padding: 10px; cursor: pointer; }
.subj-card h3 { font-size: 11px; font-weight: 500; color: #fff; }
.subj-card p { font-size: 8px; color: rgba(255,255,255,0.45); margin-top: 1px; }

/* ── PROFILE ── */
.profile-av-wrap {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: #5B21B6;
  border: 2px solid #A78BFA;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  margin: 0 auto 6px;
  overflow: hidden;
  flex-direction: column;
}
.pav-head { width: 18px; height: 18px; border-radius: 50%; background: rgba(255,255,255,0.3); margin-bottom: -3px; }
.pav-body { width: 36px; height: 20px; border-radius: 18px 18px 0 0; background: rgba(255,255,255,0.2); }

/* ── JOURNEY ── */
.journey-step {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 7px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.journey-step:last-child { border-bottom: none; }
.j-dot { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; flex-shrink: 0; }
.j-info { flex: 1; }
.j-title { font-size: 10px; color: #fff; }
.j-sub { font-size: 8px; color: rgba(255,255,255,0.35); margin-top: 1px; }
.j-week { font-size: 8px; color: rgba(255,255,255,0.3); }
</style>
</head>
<body>

<div class="stage">

  <!-- ═══════════ COACH SIDEBAR ═══════════ -->
  <div class="coach-sidebar">
    <div class="coach-avatar-wrap">
      <div class="coach-avatar" onclick="document.getElementById('pg-chat')&&navigateTo('chat')">
        <div class="coach-avatar-inner">
          <div class="avatar-body"></div>
          <div class="avatar-shoulders"></div>
        </div>
      </div>
      <div class="coach-status"></div>
    </div>

    <div>
      <div class="coach-name">Lexa</div>
      <div class="coach-role">Your Caring Mentor</div>
    </div>

    <div class="coach-tag">
      <i class="ti ti-heart" style="font-size:9px;"></i>
      Caring Mentor
    </div>

    <div class="coach-nudge">
      <strong>Hey Syril!</strong> You're close to finishing Algebra — just 2 more topics. Let's get it done today 😊
    </div>

    <div class="coach-actions">
      <button class="coach-act-btn" onclick="navigateTo('chat')">
        <i class="ti ti-message-circle"></i> Chat with Lexa
      </button>
      <button class="coach-act-btn" onclick="navigateTo('schedule')">
        <i class="ti ti-calendar"></i> Today's plan
      </button>
      <button class="coach-act-btn" onclick="navigateTo('journey')">
        <i class="ti ti-map"></i> Learning path
      </button>
    </div>

    <div style="font-size:9px;color:rgba(255,255,255,0.2);text-align:center;line-height:1.5;">
      Tap Lexa anytime<br>to get support
    </div>
  </div>

  <!-- ═══════════ PHONE ═══════════ -->
  <div class="phone-wrap">
    <div class="phone" id="app-phone">
      <div class="phone-notch"></div>
      <div class="phone-screen">

        <!-- TOPBAR -->
        <div class="topbar">

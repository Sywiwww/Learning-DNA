<script>
let p1step = 0;
const p1steps = [
  { q: "What's your grade level?", opts: ["High School","College","Grade School","Self-learner"] },
  { q: "How do you learn best?", opts: ["👁 Visual","🎵 Auditory","✋ Kinesthetic","📝 Reading"] },
  { q: "Preferred language?", opts: ["English","Filipino","Taglish","Gen Z Slang"] },
];
let persSelected = 'caring';

function selOb1(el) {
  document.querySelectorAll('#p1opts .ob-opt').forEach(e => e.classList.remove('sel'));
  el.classList.add('sel');
}

function ob1Next() {
  p1step++;
  [1,2,3,4].forEach(i => {
    const d = document.getElementById('p1d' + i);
    if (d) { d.className = 'ob-d' + (i <= p1step ? ' on' : ''); }
  });
  if (p1step >= p1steps.length) {
    document.getElementById('ph1-ob').classList.add('hide');
    document.getElementById('ph1-pers').classList.remove('hide');
    return;
  }
  const s = p1steps[p1step];
  document.getElementById('p1-question').textContent = s.q;
  document.getElementById('p1opts').innerHTML = s.opts.map((o, i) =>
    `<div class="ob-opt${i===0?' sel':''}" onclick="selOb1(this)">${o}</div>`
  ).join('');
}

function selPers(el, id) {
  document.querySelectorAll('.pers-card').forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
  persSelected = id;
}

function finishOnboarding() {
  document.getElementById('ph1-pers').classList.add('hide');
}

function navigateTo(page) {
  document.querySelectorAll('#phone-pages .pg').forEach(p => p.classList.remove('active'));
  const t = document.getElementById('pg-' + page);
  if (t) t.classList.add('active');
  document.querySelectorAll('.navbar .nav-btn').forEach(b => b.classList.remove('active'));
  const nb = document.getElementById('nb-' + page);
  if (nb) nb.classList.add('active');
}
</script>


# Learning DNA Backend Configuration
NODE_ENV=development
PORT=5000


# Database (Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# Authentication
JWT_SECRET=


# Google Gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta


# AI Chat Engine
AI_DEFAULT_PERSONALITY=friendly
AI_DEFAULT_LANGUAGE=English
AI_DEFAULT_COMMUNICATION_STYLE=friendly
AI_DEFAULT_DIFFICULTY=beginner
AI_DEFAULT_PACE=moderate
AI_MAX_HISTORY_TURNS=12
AI_REQUEST_TIMEOUT_MS=30000


# Teaching DNA
TEACHING_DNA_DEFAULT_LEARNING_STYLE=mixed
TEACHING_DNA_PROFILE_CONFIDENCE=0.35
TEACHING_DNA_ADAPTATION_HISTORY_LIMIT=20


# Learning Journey
AI_SYLLABUS_MAX_MODULES=8
AI_SYLLABUS_DEFAULT_DURATION_WEEKS=4


# Resource Recommendation
AI_RESOURCE_RECOMMENDATION_LIMIT=6
AI_ENABLE_LOW_BANDWIDTH_MODE=true


# Offline AI
AI_ENABLE_OFFLINE_CACHE=true
AI_CACHE_TTL_MINUTES=1440


# Future RAG
AI_ENABLE_RAG=false
GEMINI_EMBEDDING_MODEL=text-embedding-004
AI_VECTOR_NAMESPACE=learning-dna